---
/**
 * CommentSection.astro
 *
 * Giscus-based comment system powered by GitHub Discussions.
 *
 * ── SETUP ─────────────────────────────────────────────────────────────────
 * 1. Asegurate que el repo sea PÚBLICO
 * 2. Andá a Settings → General → Features → activá "Discussions"
 * 3. Andá a https://giscus.app, conectá tu repo y configurá:
 *    - Category: "Announcements" o la que prefieras
 * 4. Copiá los valores de data-repo-id, data-category-id y pegálos abajo
 * 5. Si cambiás el mapping o el theme, actualizalos acá también
 * ──────────────────────────────────────────────────────────────────────────
 */

const GISCUS_CONFIG = {
  // ── PASO 1: Completa con tu repo ──
  repo: 'theghettoshoes/the-ghetto-shoes-blog',
  repoId: 'PONER_ACA_EL_REPO_ID',       // ← Obtenelo de giscus.app
  category: 'Announcements',
  categoryId: 'PONER_ACA_EL_CATEGORY_ID', // ← Obtenelo de giscus.app

  // ── Opcional: ajustá si querés ──
  mapping: 'pathname',
  reactionsEnabled: '1',
  emitMetadata: '0',
  inputPosition: 'bottom',
  lang: 'es',
  loading: 'lazy',
};
---

<section class="comments-section" aria-label="Comentarios del post">
  <h2 class="comments-title">💬 Comentarios</h2>
  <p class="comments-subtitle">
    ¿Qué opinás? Dejá tu punto de vista y formemos comunidad 👇
  </p>

  <div
    id="giscus-comments"
    class="giscus-frame"
  >
    <script
      src="https://giscus.app/client.js"
      data-repo={GISCUS_CONFIG.repo}
      data-repo-id={GISCUS_CONFIG.repoId}
      data-category={GISCUS_CONFIG.category}
      data-category-id={GISCUS_CONFIG.categoryId}
      data-mapping={GISCUS_CONFIG.mapping}
      data-strict="0"
      data-reactions-enabled={GISCUS_CONFIG.reactionsEnabled}
      data-emit-metadata={GISCUS_CONFIG.emitMetadata}
      data-input-position={GISCUS_CONFIG.inputPosition}
      data-theme="dark_tritanopia"
      data-lang={GISCUS_CONFIG.lang}
      data-loading={GISCUS_CONFIG.loading}
      crossorigin="anonymous"
      async
    >
    </script>
  </div>

  <!-- Fallback para cuando no está configurado -->
  {GISCUS_CONFIG.repoId === 'PONER_ACA_EL_REPO_ID' && (
    <div class="comments-setup-notice">
      <p>
        ⚡ Los comentarios están desactivados por ahora.
        Una vez que configures Giscus en <code>giscus.app</code> y pegues los IDs
        en <code>src/components/CommentSection.astro</code>, los comentarios aparecerán
        automáticamente en cada post.
      </p>
    </div>
  )}
</section>

<style>
  .comments-section {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 3px dashed var(--color-secondary);
  }

  .comments-title {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .comments-subtitle {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-light);
    opacity: 0.7;
    margin-bottom: var(--space-lg);
  }

  .giscus-frame {
    min-height: 400px;
  }

  .comments-setup-notice {
    background-color: var(--color-surface);
    border: 2px solid var(--color-secondary);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
    color: var(--color-text-dark);
    font-family: var(--font-body);
    font-size: 0.95rem;
    text-align: center;
  }

  .comments-setup-notice code {
    background-color: rgba(0, 0, 0, 0.1);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85rem;
  }
</style>
