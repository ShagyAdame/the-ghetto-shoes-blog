---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Inicio', href: base },
  { label: 'Posts', href: `${base}posts` },
  { label: 'About', href: `${base}about` },
  { label: 'Archivo', href: `${base}archive` },
];

function isActive(href: string): boolean {
  if (href === base) return currentPath === href;
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <div class="header-container">
    <div class="header-left">
      <a href={base} class="logo" aria-label="THE GHETTO SHOE'S — Inicio">
        <span class="logo-text">THE GHETTO SHOE'S</span>
      </a>

      <img
        src={`${base}images/logo.png`}
        alt="The Ghetto Shoe's Logo"
        class="header-logo"
        width="120"
        height="auto"
      />
    </div>

    <button class="hamburger" aria-label="Abrir menú de navegación" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <nav class="nav" aria-label="Navegación principal">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li class="nav-item">
              <a
                href={item.href}
                class="nav-link"
                aria-current={isActive(item.href) ? 'page' : undefined}
              >{item.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const hamburger = document.querySelector('.hamburger');
  const nav = document.querySelector('.nav');

  if (hamburger && nav) {
    hamburger.addEventListener('click', () => {
      const expanded = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('nav--open');
    });

    // Close nav when clicking a link (mobile)
    nav.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener('click', () => {
        hamburger.setAttribute('aria-expanded', 'false');
        nav.classList.remove('nav--open');
      });
    });
  }
</script>

<style>
  /* ── Site Header ── */
  .site-header {
    background-color: var(--color-primary);
    border-bottom: 3px solid var(--color-secondary);
    padding: var(--space-md) 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  /* ── Header Container ── */
  .header-container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }

  /* ── Left side: logo text + image ── */
  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-shrink: 0;
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .header-logo {
    display: block;
    width: 100px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(255, 179, 71, 0.4));
    transition: filter 0.2s ease;
    flex-shrink: 0;
  }

  .header-logo:hover {
    filter: drop-shadow(0 0 14px rgba(255, 179, 71, 0.7));
  }

  .logo-text {
    font-family: 'Platinum Sign', 'Boston Caps', cursive;
    font-size: clamp(1rem, 2.5vw, 1.5rem);
    color: var(--color-accent);
    letter-spacing: 0.05em;
    line-height: 1;
    white-space: nowrap;
    text-shadow:
      0 0 6px rgba(255, 179, 71, 0.5),
      0 0 14px rgba(255, 179, 71, 0.25),
      1px 1px 3px rgba(0, 0, 0, 0.4);
    transition: color 0.2s ease, text-shadow 0.2s ease;
  }

  .logo:hover .logo-text {
    color: var(--color-cta);
    text-shadow:
      0 0 6px rgba(201, 95, 95, 0.5),
      0 0 14px rgba(201, 95, 95, 0.25),
      1px 1px 3px rgba(0, 0, 0, 0.4);
  }

  /* ── Navigation (desktop) ── */

  .nav-list {
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--space-xs) 0;
    position: relative;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: var(--color-cta);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-cta);
    transition: width 0.2s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link[aria-current="page"] {
    color: var(--color-accent);
  }

  .nav-link[aria-current="page"]::after {
    width: 100%;
    background-color: var(--color-accent);
  }

  /* ── Hamburger (mobile only) ── */

  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    flex-direction: column;
    gap: 4px;
    position: relative;
    z-index: 20;
  }

  .hamburger-line {
    display: block;
    width: 24px;
    height: 3px;
    background-color: var(--color-accent);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Responsive: tablets ── */

  @media (max-width: 900px) {
    .header-logo {
      width: 72px;
    }
  }

  /* ── Responsive: mobile ── */

  @media (max-width: 639px) {
    .site-header {
      padding: var(--space-xs) 0;
    }

    .header-container {
      padding: 0 var(--space-sm);
      /* keep flex + space-between from base */
    }

    /* Hide title text on mobile */
    .logo-text {
      display: none;
    }

    /* Hide the empty anchor wrapper on mobile */
    .logo {
      display: none;
    }

    /* Show logo image smaller */
    .header-logo {
      display: block;
      width: 36px;
      filter: drop-shadow(0 0 4px rgba(255, 179, 71, 0.3));
    }

    /* Hamburger always clickable */
    .hamburger {
      display: flex;
      padding: 16px;
      margin: 0;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
      min-width: 52px;
      min-height: 44px;
      justify-content: center;
      align-items: center;
    }

    /* Mobile dropdown nav */
    .nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      background-color: var(--color-primary);
      border-bottom: 3px solid var(--color-secondary);
      z-index: 200;
    }

    .nav--open {
      display: block;
    }

    .nav-list {
      flex-direction: column;
      padding: var(--space-md);
      gap: var(--space-md);
    }

    .nav-link {
      display: block;
      padding: var(--space-sm) 0;
      font-size: 1.125rem;
    }
  }
</style>
