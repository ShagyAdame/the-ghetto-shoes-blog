---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-content">
      <p class="footer-copyright">
        &copy; {currentYear} The Ghetto Shoe's. Todos los derechos reservados.
      </p>

      <div class="footer-links">
        <a
          href="https://www.youtube.com/@TheGuettoShoes"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link"
          aria-label="YouTube de The Ghetto Shoe's"
        >
          YouTube
        </a>
        <a href={`${base}rss.xml`} class="footer-link" aria-label="RSS Feed">
          RSS
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary);
    border-top: 3px solid var(--color-secondary);
    padding: var(--space-xl) 0;
    margin-top: var(--space-3xl);
  }

  .footer-container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 var(--space-lg);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-copyright {
    font-size: 0.875rem;
    color: var(--color-surface);
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-cta);
  }
</style>
