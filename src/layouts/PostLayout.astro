---
import type { CollectionEntry } from 'astro:content';
import { render } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TagBadge from '../components/TagBadge.astro';
import CommentSection from '../components/CommentSection.astro';

export interface Props {
  post: CollectionEntry<'posts'>;
  prevPost?: CollectionEntry<'posts'> | null;
  nextPost?: CollectionEntry<'posts'> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { data } = post;
const { Content } = await render(post);

const siteUrl = 'https://theghettoshoes.github.io';
const postUrl = `${siteUrl}/posts/${post.id}/`;

// Get the hero image: from frontmatter image, or first image from rendered content
const imageSrc = data.image
  ? `/images/${data.image}`
  : null;
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={data.image}
  ogType="article"
>
  <article class="post-article">
    <!-- Hero Image -->
    {imageSrc && (
      <div class="post-hero">
        <img
          src={imageSrc}
          alt={data.title}
          class="post-hero-image"
        />
        <div class="post-hero-overlay"></div>
      </div>
    )}

    <!-- Post Header -->
    <header class="post-header">
      <time class="post-date" datetime={data.date.toISOString()}>
        {new Intl.DateTimeFormat('es-ES', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
          timeZone: 'UTC',
        }).format(data.date)}
      </time>

      <h1 class="post-title">{data.title}</h1>

      {data.tags && data.tags.length > 0 && (
        <div class="post-tags">
          {data.tags.map((tag) => <TagBadge tag={tag} />)}
        </div>
      )}

      {data.author && (
        <p class="post-author">Por {data.author}</p>
      )}
    </header>

    <!-- Post Content -->
    <div class="post-content">
      <Content />
    </div>

    <!-- Share Buttons -->
    <ShareButtons url={postUrl} title={data.title} />

    <!-- Previous / Next Navigation -->
    <nav class="post-nav" aria-label="Navegación entre posts">
      <div class="post-nav-inner">
        {prevPost ? (
          <a href={`/posts/${prevPost.id}/`} class="post-nav-link post-nav-prev">
            <span class="post-nav-direction">← Post anterior</span>
            <span class="post-nav-title">{prevPost.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}

        {nextPost ? (
          <a href={`/posts/${nextPost.id}/`} class="post-nav-link post-nav-next">
            <span class="post-nav-direction">Post siguiente →</span>
            <span class="post-nav-title">{nextPost.data.title}</span>
          </a>
        ) : (
          <div></div>
        )}
      </div>
    </nav>

    <!-- Comment Section -->
    <CommentSection />
  </article>
</BaseLayout>

<style>
  .post-article {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-xl) 0;
  }

  /* ── Hero Image ── */

  .post-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
    border: 3px solid var(--color-secondary);
  }

  @media (max-width: 639px) {
    .post-hero {
      aspect-ratio: 4 / 3;
    }
  }

  .post-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      var(--color-primary) 20%,
      transparent 80%
    );
  }

  /* ── Post Header ── */

  .post-header {
    margin-bottom: var(--space-2xl);
  }

  .post-date {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-light);
    opacity: 0.7;
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    color: var(--color-accent);
    margin: 0 0 var(--space-md) 0;
    line-height: 1.15;
    letter-spacing: 0.02em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: var(--space-sm);
  }

  .post-author {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-light);
    opacity: 0.6;
    font-style: italic;
  }

  /* ── Post Content ── */

  .post-content {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: var(--space-2xl);
  }

  .post-content h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    color: var(--color-accent);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: 2px dashed var(--color-secondary);
  }

  .post-content h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    color: var(--color-accent);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .post-content p {
    margin-bottom: var(--space-md);
    color: var(--color-text-light);
  }

  .post-content a {
    color: var(--color-cta);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .post-content a:hover {
    color: var(--color-accent);
  }

  .post-content img {
    width: 100%;
    border-radius: var(--radius-md);
    margin: var(--space-lg) 0;
    border: 2px solid var(--color-secondary);
  }

  .post-content ul,
  .post-content ol {
    margin-bottom: var(--space-md);
    padding-left: var(--space-xl);
    color: var(--color-text-light);
  }

  .post-content li {
    margin-bottom: var(--space-sm);
  }

  .post-content ul {
    list-style: disc;
  }

  .post-content ol {
    list-style: decimal;
  }

  .post-content blockquote {
    border-left: 4px solid var(--color-cta);
    padding-left: var(--space-md);
    margin: var(--space-lg) 0;
    color: var(--color-text-light);
    opacity: 0.85;
    font-style: italic;
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-lg) 0;
    font-size: 0.9rem;
    background-color: var(--color-surface);
    color: var(--color-text-dark);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .post-content th,
  .post-content td {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-secondary);
    text-align: left;
  }

  .post-content th {
    background-color: var(--color-primary);
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-weight: normal;
    letter-spacing: 0.05em;
  }

  .post-content td {
    color: var(--color-text-dark);
  }

  .post-content code {
    background-color: rgba(0, 0, 0, 0.3);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.875rem;
    font-family: 'Courier New', monospace;
  }

  .post-content pre {
    background-color: rgba(0, 0, 0, 0.4);
    padding: var(--space-md);
    border-radius: var(--radius-md);
    overflow-x: auto;
    border: 1px solid var(--color-secondary);
    margin: var(--space-lg) 0;
  }

  .post-content pre code {
    background: none;
    padding: 0;
  }

  .post-content hr {
    border: none;
    border-top: 3px dashed var(--color-secondary);
    margin: var(--space-2xl) 0;
  }

  /* ── Post Navigation ── */

  .post-nav {
    margin-top: var(--space-2xl);
  }

  .post-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 2px solid var(--color-secondary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
    flex: 1;
    max-width: 50%;
  }

  .post-nav-link:hover {
    border-color: var(--color-cta);
    background-color: rgba(201, 95, 95, 0.1);
  }

  .post-nav-next {
    text-align: right;
  }

  .post-nav-direction {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-cta);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .post-nav-title {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--color-text-light);
    opacity: 0.8;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 639px) {
    .post-nav-inner {
      flex-direction: column;
    }

    .post-nav-link {
      max-width: 100%;
    }

    .post-nav-next {
      text-align: left;
    }
  }
</style>
