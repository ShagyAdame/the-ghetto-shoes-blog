---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
}

const {
  title,
  description = "Blog oficial de The Ghetto Shoe's — lanzamientos, cultura urbana y estilo.",
  image,
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://shagyadame.github.io/the-ghetto-shoes-blog';
const pageTitle = `${title} | The Ghetto Shoe's`;
const canonicalUrl = Astro.url.href;
const ogImage = image
  ? `${siteUrl}${image.startsWith('/') ? image : `/images/${image}`}`
  : undefined;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Fonts: Inter for body text -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>

    <style is:global>
      /* ── Local Fonts ── */
      @font-face {
        font-family: 'Boston Caps';
        src: url('/fonts/BOSTON CAPS.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Full Pack 2025';
        src: url('/fonts/full Pack 2025.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign';
        src: url('/fonts/Platinum Sign.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign Over';
        src: url('/fonts/Platinum Sign Over.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign Under';
        src: url('/fonts/Platinum Sign Under.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      /* ── Decorative sneaker silhouettes ── */
      .page-sneakers {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
      }

      .sneaker-left,
      .sneaker-right {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: clamp(140px, 12vw, 220px);
        height: auto;
        color: var(--color-accent);
        opacity: 0.08;
      }

      .sneaker-left {
        left: clamp(-40px, -2vw, 0px);
        transform: translateY(-50%) scaleX(-1);
      }

      .sneaker-right {
        right: clamp(-40px, -2vw, 0px);
      }

      @media (max-width: 1024px) {
        .sneaker-left,
        .sneaker-right {
          width: 100px;
          opacity: 0.06;
        }

        .sneaker-left {
          left: -30px;
        }

        .sneaker-right {
          right: -30px;
        }
      }

      @media (max-width: 639px) {
        .sneaker-left,
        .sneaker-right {
          width: 70px;
          opacity: 0.05;
        }

        .sneaker-left {
          left: -20px;
        }

        .sneaker-right {
          right: -20px;
        }
      }
    </style>
  </head>
  <body>
    <div class="page-sneakers" aria-hidden="true">
      <svg class="sneaker-left" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M10 80 L15 40 Q20 20 40 15 L100 10 Q120 8 140 15 L170 25 Q185 30 190 45 L195 60 Q198 70 195 80 L190 90 Q188 95 185 95 L160 95 Q150 95 145 90 L140 80 L100 80 L90 95 Q85 100 75 100 L25 100 Q15 100 10 90 L8 85 Z" fill="currentColor"/>
        <rect x="50" y="30" width="60" height="15" rx="4" fill="white" opacity="0.15"/>
        <circle cx="165" cy="70" r="20" fill="white" opacity="0.1"/>
      </svg>

      <svg class="sneaker-right" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M190 80 L185 40 Q180 20 160 15 L100 10 Q80 8 60 15 L30 25 Q15 30 10 45 L5 60 Q2 70 5 80 L10 90 Q12 95 15 95 L40 95 Q50 95 55 90 L60 80 L100 80 L110 95 Q115 100 125 100 L175 100 Q185 100 190 90 L192 85 Z" fill="currentColor"/>
        <rect x="90" y="30" width="60" height="15" rx="4" fill="white" opacity="0.15"/>
        <circle cx="35" cy="70" r="20" fill="white" opacity="0.1"/>
      </svg>
    </div>
    <div class="page-wrapper">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
