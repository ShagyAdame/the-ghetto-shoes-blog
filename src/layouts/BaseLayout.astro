---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
}

const {
  title,
  description = "Blog oficial de The Ghetto Shoe's — lanzamientos, cultura urbana y estilo.",
  image,
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://shagyadame.github.io/the-ghetto-shoes-blog';
const pageTitle = `${title} | The Ghetto Shoe's`;
const canonicalUrl = Astro.url.href;
const ogImage = image
  ? `${siteUrl}${image.startsWith('/') ? image : `/images/${image}`}`
  : undefined;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Fonts: Inter for body text -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>

    <style is:global>
      /* ── Local Fonts ── */
      @font-face {
        font-family: 'Boston Caps';
        src: url('/fonts/BOSTON CAPS.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Full Pack 2025';
        src: url('/fonts/full Pack 2025.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign';
        src: url('/fonts/Platinum Sign.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign Over';
        src: url('/fonts/Platinum Sign Over.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      @font-face {
        font-family: 'Platinum Sign Under';
        src: url('/fonts/Platinum Sign Under.ttf') format('truetype');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
    </style>
  </head>
  <body>
    <div class="page-wrapper">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
