---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TagBadge from '../components/TagBadge.astro';

const allPosts = await getCollection('posts', ({ data }) => data.published !== false);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group posts by year-month
type MonthEntry = {
  label: string;
  iso: string;
  posts: typeof sortedPosts;
};

const groupMap = new Map<string, typeof sortedPosts>();

for (const post of sortedPosts) {
  const d = post.data.date;
  const key = `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}`;

  if (!groupMap.has(key)) {
    groupMap.set(key, []);
  }
  groupMap.get(key)!.push(post);
}

// Build sorted groups (newest first)
const groups: MonthEntry[] = Array.from(groupMap.entries())
  .sort(([a], [b]) => b.localeCompare(a))
  .map(([key, posts]) => {
    const [year, month] = key.split('-');
    const date = new Date(Date.UTC(parseInt(year), parseInt(month) - 1, 1));
    return {
      label: new Intl.DateTimeFormat('es-ES', {
        year: 'numeric',
        month: 'long',
        timeZone: 'UTC',
      }).format(date),
      iso: `${key}-01`,
      posts,
    };
  });

const totalPosts = sortedPosts.length;
---

<BaseLayout title="Archivo" description="Archivo mensual de todos los posts publicados en The Ghetto Shoe's.">
  <section class="archive-page">
    <header class="archive-header">
      <h1>Archivo</h1>
      <p class="archive-count">{totalPosts} {totalPosts === 1 ? 'post publicado' : 'posts publicados'}</p>
    </header>

    {groups.length > 0 ? (
      <div class="archive-months">
        {groups.map((group) => (
          <article class="archive-month" aria-labelledby={`month-${group.iso}`}>
            <h2 id={`month-${group.iso}`} class="archive-month-title">
              <time datetime={group.iso}>{group.label}</time>
            </h2>

            <ul class="archive-post-list">
              {group.posts.map((post) => (
                <li class="archive-post-item">
                  <a href={`/posts/${post.id}/`} class="archive-post-link">
                    <time
                      class="archive-post-date"
                      datetime={post.data.date.toISOString()}
                    >
                      {new Intl.DateTimeFormat('es-ES', {
                        day: 'numeric',
                        month: 'short',
                        timeZone: 'UTC',
                      }).format(post.data.date)}
                    </time>

                    <span class="archive-post-title">{post.data.title}</span>
                  </a>

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="archive-post-tags">
                      {post.data.tags.map((tag) => (
                        <TagBadge tag={tag} />
                      ))}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    ) : (
      <div class="archive-empty">
        <p>Aún no hay posts publicados. ¡Vuelve pronto!</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .archive-page {
    padding: var(--space-2xl) 0;
  }

  .archive-header {
    margin-bottom: var(--space-2xl);
    border-bottom: 3px dashed var(--color-secondary);
    padding-bottom: var(--space-md);
  }

  .archive-header h1 {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 3rem);
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .archive-count {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-text-light);
    opacity: 0.7;
    margin: 0;
  }

  /* ── Month Groups ── */

  .archive-month {
    margin-bottom: var(--space-2xl);
  }

  .archive-month-title {
    font-family: var(--font-heading);
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    color: var(--color-cta);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: 2px solid var(--color-secondary);
  }

  .archive-month-title time {
    letter-spacing: 0.03em;
  }

  /* ── Post List ── */

  .archive-post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .archive-post-item {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs) var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid rgba(122, 77, 38, 0.3);
    transition: background-color 0.15s ease;
  }

  .archive-post-item:hover {
    background-color: rgba(122, 77, 38, 0.1);
    margin: 0 calc(-1 * var(--space-md));
    padding-left: var(--space-md);
    padding-right: var(--space-md);
    border-radius: var(--radius-sm);
  }

  .archive-post-link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-md);
    text-decoration: none;
    color: inherit;
    flex: 1;
    min-width: 0;
  }

  .archive-post-date {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--color-text-light);
    opacity: 0.6;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 5ch;
  }

  .archive-post-title {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-light);
    line-height: 1.4;
    transition: color 0.2s ease;
    /* Clamp to 2 lines */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .archive-post-link:hover .archive-post-title {
    color: var(--color-cta);
  }

  .archive-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    width: 100%;
    padding-left: calc(5ch + var(--space-md));
  }

  /* ── Empty State ── */

  .archive-empty {
    background-color: var(--color-surface);
    color: var(--color-text-dark);
    padding: var(--space-3xl) var(--space-lg);
    text-align: center;
    border: 3px dashed var(--color-secondary);
    border-radius: var(--radius-md);
  }

  .archive-empty p {
    font-size: 1.125rem;
    color: var(--color-text-dark);
    margin: 0;
  }

  /* ── Responsive ── */

  @media (max-width: 639px) {
    .archive-post-item {
      flex-direction: column;
      gap: var(--space-xs);
    }

    .archive-post-tags {
      padding-left: 0;
    }
  }
</style>
