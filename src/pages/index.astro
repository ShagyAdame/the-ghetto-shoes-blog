---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPost from '../components/HeroPost.astro';
import PostGrid from '../components/PostGrid.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const allPosts = await getCollection('posts', ({ data }) => data.published !== false);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const featuredPost = sortedPosts.length > 0 ? sortedPosts[0] : null;
const recentPosts = sortedPosts.slice(1, 7); // Next 6 posts
---

<BaseLayout title="Inicio" description="Blog oficial de The Ghetto Shoe's — lanzamientos, cultura urbana y estilo.">
  <!-- Hero Section -->
  <section class="home-hero">
    <div class="container">
      {featuredPost ? (
        <HeroPost post={featuredPost} />
      ) : (
        <div class="home-hero-empty">
          <h1>The Ghetto Shoe's</h1>
          <p class="hero-subtitle">
            Lanzamientos, cultura urbana y estilo desde el corazón del barrio.
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- Recent Posts Grid -->
  {recentPosts.length > 0 && (
    <section class="container">
      <PostGrid
        posts={recentPosts}
        title="Posts recientes"
      />
    </section>
  )}

  <!-- Brand Section -->
  <section class="brand-section container">
    <div class="brand-card">
      <h2>¿Qué es The Ghetto Shoe's?</h2>
      <p>
        The Ghetto Shoe's no es solo una marca de zapatillas — es una forma de ver la calle,
        de caminarla con estilo y de contar las historias que cada par de zapatos lleva consigo.
        Acá vas a encontrar lanzamientos, reseñas, cultura urbana y todo lo que mueve el asfalto.
      </p>
      <a href={`${base}about`} class="brand-link">Conocé más →</a>
    </div>
  </section>

  <!-- Social CTA -->
  <section class="cta-section container">
    <div class="cta-card">
      <h2>Síguenos en nuestras redes sociales</h2>
      <p>
        Reviews, unboxings, lanzamientos exclusivos y todo el contenido detrás del asfalto.
        Seguinos y no te pierdas ningún drop.
      </p>

      <div class="social-cta-grid">
        <a
          href="https://www.instagram.com/shagy._.oficial?igsh=MWg2YmtsaWt2Y3E2YQ%3D%3D&utm_source=qr"
          target="_blank"
          rel="noopener noreferrer"
          class="social-cta-link social-cta-instagram"
          aria-label="Instagram de The Ghetto Shoe's"
        >
          <svg class="social-cta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
          <span>Instagram</span>
        </a>

        <a
          href="https://www.tiktok.com/@shagy._.oficial?_r=1&_t=ZS-97J08SorCG0"
          target="_blank"
          rel="noopener noreferrer"
          class="social-cta-link social-cta-tiktok"
          aria-label="TikTok de The Ghetto Shoe's"
        >
          <svg class="social-cta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
          </svg>
          <span>TikTok</span>
        </a>

        <a
          href="https://www.facebook.com/share/1HAtzjzG8k/?mibextid=wwXIfr"
          target="_blank"
          rel="noopener noreferrer"
          class="social-cta-link social-cta-facebook"
          aria-label="Facebook de The Ghetto Shoe's"
        >
          <svg class="social-cta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          <span>Facebook</span>
        </a>

        <a
          href="https://www.youtube.com/@TheGuettoShoes"
          target="_blank"
          rel="noopener noreferrer"
          class="social-cta-link social-cta-youtube"
          aria-label="YouTube de The Ghetto Shoe's"
        >
          <svg class="social-cta-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          <span>YouTube</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */

  .home-hero {
    padding: var(--space-2xl) 0 0 0;
  }

  .home-hero-empty {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .home-hero-empty h1 {
    font-size: clamp(2.5rem, 8vw, 5rem);
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  /* ── Brand Section ── */

  .brand-section {
    margin: var(--space-2xl) auto;
  }

  .brand-card {
    background-color: var(--color-surface);
    color: var(--color-text-dark);
    border: 3px solid var(--color-secondary);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
  }

  .brand-card h2 {
    font-family: var(--font-heading);
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
  }

  .brand-card p {
    color: var(--color-text-dark);
    max-width: 600px;
    margin: 0 auto var(--space-lg);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .brand-link {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-cta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: var(--space-sm) var(--space-lg);
    border: 2px solid var(--color-cta);
    border-radius: var(--radius-sm);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .brand-link:hover {
    background-color: var(--color-cta);
    color: var(--color-text-light);
  }

  /* ── CTA Section ── */

  .cta-section {
    margin: var(--space-2xl) auto var(--space-3xl);
  }

  .cta-card {
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      var(--color-secondary) 100%
    );
    border: 3px solid var(--color-cta);
    border-radius: var(--radius-md);
    padding: var(--space-2xl) var(--space-lg);
    text-align: center;
  }

  .cta-card h2 {
    font-family: var(--font-heading);
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
  }

  .cta-card p {
    color: var(--color-text-light);
    max-width: 500px;
    margin: 0 auto var(--space-lg);
    font-size: 1.0625rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  .social-cta-grid {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .social-cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: var(--space-sm) var(--space-lg);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-radius: var(--radius-sm);
    border: 2px solid transparent;
    transition: all 0.2s ease;
    background-color: rgba(0, 0, 0, 0.25);
    color: var(--color-text-light);
  }

  .social-cta-link:hover {
    transform: translateY(-3px);
    color: var(--color-text-light);
  }

  .social-cta-instagram:hover {
    background-color: #E1306C;
    border-color: #E1306C;
  }

  .social-cta-tiktok:hover {
    background-color: #010101;
    border-color: #00F2EA;
    box-shadow: 0 0 12px rgba(0, 242, 234, 0.3);
  }

  .social-cta-facebook:hover {
    background-color: #1877F2;
    border-color: #1877F2;
  }

  .social-cta-youtube:hover {
    background-color: #FF0000;
    border-color: #FF0000;
  }

  .social-cta-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .social-cta-link span {
      display: none;
    }

    .social-cta-link {
      padding: var(--space-sm);
    }

    .social-cta-icon {
      width: 26px;
      height: 26px;
    }
  }
</style>
